# Rumbledore local environment template.
# Copy to .env.local for local overrides; keep real secrets out of git.

# Runtime
NODE_ENV=
DATABASE_URL=
REDIS_URL=
BETTER_AUTH_SECRET= # secret-scan:ignore - documented empty placeholder
BETTER_AUTH_URL=
CREDENTIAL_ENCRYPTION_KEY= # secret-scan:ignore - documented empty placeholder

# Supabase Realtime config. Leave empty for local no-op/mock realtime.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY= # secret-scan:ignore - documented empty placeholder
SUPABASE_SERVICE_ROLE_KEY= # secret-scan:ignore - documented empty placeholder
SUPABASE_JWT_SECRET= # secret-scan:ignore - documented empty placeholder
MOCK_REALTIME=

# Inngest jobs. Leave empty for local no-op enqueueing; set INNGEST_DEV=true
# when running `pnpm jobs:dev`, or provide cloud keys/base URLs in deployed env.
INNGEST_DEV=
INNGEST_DEVSERVER_URL=
INNGEST_BASE_URL=
INNGEST_API_BASE_URL=
INNGEST_EVENT_API_BASE_URL=
INNGEST_EVENT_KEY= # secret-scan:ignore - documented empty placeholder
INNGEST_SIGNING_KEY= # secret-scan:ignore - documented empty placeholder
INNGEST_SIGNING_KEY_FALLBACK= # secret-scan:ignore - documented empty placeholder

# PWA Web Push config. Public key is browser-safe; private key stays server-only.
# Leave empty for local mock/no-op push delivery.
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY= # secret-scan:ignore - documented empty placeholder
WEB_PUSH_SUBJECT=
MOCK_PUSH=

# Entitlement gates. Dev override defaults on in dev/test and is forbidden in production.
ENTITLEMENTS_DEV_OVERRIDE=
ENTITLEMENTS_GATE_ARENA_ADVANCED=
ENTITLEMENTS_AI_POSTS_PER_WEEK=
ENTITLEMENTS_MAX_PREMIUM_LEAGUES_PER_USER=
ENTITLEMENTS_INDIVIDUAL_LEAGUES_COVERED=

# OAuth social-login stub. Leave both empty for mocked Google auth routes.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET= # secret-scan:ignore - documented empty placeholder

# Yahoo Fantasy OAuth. Leave client vars empty for local fixture-backed mock connect.
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET= # secret-scan:ignore - documented empty placeholder
YAHOO_REDIRECT_URI=
YAHOO_OAUTH_SCOPE=fspt-r

# ESPN cookie auth. Optional until a user connects a league.
ESPN_SWID=
ESPN_S2= # secret-scan:ignore - documented empty placeholder
ESPN_TEST_LEAGUE_ID=
ESPN_TEST_SEASON=

# Paid service credentials. Leave keys empty for local mock mode.
ANTHROPIC_API_KEY= # secret-scan:ignore - documented empty placeholder
ANTHROPIC_MODEL_TIER=cheap
THE_ODDS_API_KEY= # secret-scan:ignore - documented empty placeholder
SPORTSDATAIO_API_KEY= # secret-scan:ignore - documented empty placeholder
TAVILY_API_KEY= # secret-scan:ignore - documented empty placeholder
VOYAGE_API_KEY= # secret-scan:ignore - documented empty placeholder
VOYAGE_EMBEDDING_MODEL=voyage-4-lite
BROWSERBASE_API_KEY= # secret-scan:ignore - documented empty placeholder

# Optional AI generation provider override. Leave AI_LLM_PROVIDER_KEY empty or
# "anthropic" for the normal Anthropic path. Set "custom" only when the custom
# endpoint block is complete.
AI_LLM_PROVIDER_KEY=
AI_MODEL_ROUTE_JSON=
AI_CUSTOM_MODEL_KIND=
AI_CUSTOM_MODEL_BASE_URL=
AI_CUSTOM_MODEL_ID=
AI_CUSTOM_MODEL_API_KEY= # secret-scan:ignore - documented empty placeholder
AI_CUSTOM_MODEL_API_KEY_VAR= # secret-scan:ignore - env var name pointer, not a credential
AI_CUSTOM_MODEL_ALLOW_UNAUTHENTICATED=

# Paid service mode toggles.
# true = force mock, false = require the corresponding key, empty = real if key exists else mock.
MOCK_ANTHROPIC=
MOCK_ODDS=
MOCK_SPORTSDATAIO=
MOCK_TAVILY=
MOCK_VOYAGE=
MOCK_BROWSERBASE=

# Cost guard caps. Defaults are conservative; lower locally when proving fallback.
SPEND_GUARD_WINDOW=
SPEND_GUARD_ANTHROPIC_TOKENS= # secret-scan:ignore - token count cap, not a credential
SPEND_GUARD_ODDS_REQUESTS=
SPEND_GUARD_SPORTSDATAIO_REQUESTS=
SPEND_GUARD_TAVILY_REQUESTS=
SPEND_GUARD_VOYAGE_REQUESTS=

# Manual provider validation only. Leave empty for normal local/CI test runs.
LIVE_SMOKE=
VCR_MODE=

# Docker compose host-port overrides. If changed, update DATABASE_URL/REDIS_URL too.
RUMBLEDORE_DB_PORT=
RUMBLEDORE_REDIS_PORT=

# Build hygiene.
NEXT_TELEMETRY_DISABLED=
