/* ───────── histogram ───────── */
function buildHistogram(id){
  const bars=24,W=300,H=150,pad=12,vals=[];for(let i=0;i<bars;i++){const x=(i-bars/2)/4.2;vals.push(Math.exp(-x*x/1.5));}
  const max=Math.max(...vals),bw=(W-pad*2)/bars;let g=rOpen(W,H);
  vals.forEach((v,i)=>{const bh=(v/max)*(H-pad*2),x=pad+i*bw,y=H-pad-bh;const mid=Math.abs(i-bars/2)<1.5,lo=i<bars*.16,hi=i>bars*.84;
    const col=mid?C.amber:(lo?C.coral:(hi?C.jade:C.hair2));
    g+='<rect x="'+(x+1)+'" y="'+y+'" width="'+(bw-2)+'" height="'+bh+'" rx="1.5" fill="'+col+'" opacity="'+(mid?1:.82)+'">'+anim('<animate attributeName="height" from="0" to="'+bh+'" dur="0.5s" begin="'+(i*0.012)+'s" fill="freeze"/><animate attributeName="y" from="'+(H-pad)+'" to="'+y+'" dur="0.5s" begin="'+(i*0.012)+'s" fill="freeze"/>')+'</rect>';});
  g+='<line x1="'+(pad+bars/2*bw)+'" y1="'+(pad-2)+'" x2="'+(pad+bars/2*bw)+'" y2="'+(H-pad)+'" stroke="'+C.amber+'" stroke-width="1" stroke-dasharray="2 2" opacity=".7"/></svg>';
  put(id,g);
}
