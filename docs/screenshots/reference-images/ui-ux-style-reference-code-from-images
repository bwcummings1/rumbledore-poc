  rows.forEach((r,i)=>{const y=padY+i*rh+rh/2;g+='<text x="'+padX+'" y="'+(y+3)+'" font-family="JetBrains Mono" font-size="9" fill="'+C.ink2+'">'+r[0]+'</text>';g+='<rect x="'+trackX+'" y="'+(y-6)+'" width="'+trackW+'" height="12" rx="3" fill="rgba(255,255,255,.05)"/>';});
  g+='<g clip-path="url(#cbl-'+id+')">';
  rows.forEach((r,i)=>{const y=padY+i*rh+rh/2;g+='<rect x="'+trackX+'" y="'+(y-3.5)+'" width="'+(xv(r[1])-trackX)+'" height="7" rx="3.5" fill="'+C.lilac+'"/>';});
  g+='</g>';
  rows.forEach((r,i)=>{const y=padY+i*rh+rh/2;g+='<line x1="'+xv(r[2])+'" y1="'+(y-7)+'" x2="'+xv(r[2])+'" y2="'+(y+7)+'" stroke="'+C.amber+'" stroke-width="2"/>';g+='<text x="'+(W-padX)+'" y="'+(y+3)+'" text-anchor="end" font-family="JetBrains Mono" font-size="9" fill="'+C.ink2+'">'+r[1]+'</text>';});
  g+='</svg>';put(id,g);
}
/* ───────── node graph ───────── */
function buildNodeGraph(id){
  const nodes=[{x:140,y:30,l:'A',ai:1},{x:58,y:78,l:'N',c:C.lilac},{x:222,y:70,l:'R',c:C.steel},{x:92,y:142,l:'D',c:C.jade},{x:205,y:142,l:'M',c:C.amber}];
  const edges=[[0,1],[0,2],[0,3],[0,4],[1,3],[2,4]],W=280,H=170;let g=rOpen(W,H);
  edges.forEach((e,i)=>{const a=nodes[e[0]],b=nodes[e[1]];g+='<line x1="'+a.x+'" y1="'+a.y+'" x2="'+b.x+'" y2="'+b.y+'" stroke="'+C.hair2+'" stroke-width="1" opacity="'+(RM?.6:0)+'">'+anim('<animate attributeName="opacity" from="0" to=".6" dur="0.5s" begin="'+(i*0.08)+'s" fill="freeze"/>')+'</line>';});
  nodes.forEach(n=>{if(n.ai){g+='<circle cx="'+n.x+'" cy="'+n.y+'" r="16" fill="'+C.lilac+'" style="filter:drop-shadow(0 0 8px '+C.glow+')">'+anim('<animate attributeName="r" values="16;18;16" dur="2.4s" repeatCount="indefinite"/>')+'</circle>';}else{g+='<circle cx="'+n.x+'" cy="'+n.y+'" r="13" fill="'+n.c+'"/>';}
    g+='<text x="'+n.x+'" y="'+(n.y+4)+'" text-anchor="middle" font-family="JetBrains Mono" font-size="'+(n.ai?11:10)+'" font-weight="600" fill="#0b0c14">'+n.l+'</text>';});
  g+='</svg>';put(id,g);
}
/* ───────── equalizer ───────── */
function buildEq(id){const el=document.getElementById(id);if(!el)return;
  el.innerHTML=Array.from({length:18},()=>'<i style="animation-delay:-'+(Math.random()*1.1).toFixed(2)+'s;animation-duration:'+(0.8+Math.random()*0.8).toFixed(2)+'s"></i>').join('');}

function renderAllCharts(){
  buildLineArea('c-line');buildMultiLine('c-multiline');buildSpark('c-spark');
  buildBars('c-bars');buildGrouped('c-grouped');buildStacked('c-stacked');
  buildHBars('c-hbars');buildRange('c-range');
  buildRadar('c-radar',[.92,.78,.7,.95,.74,.88],[.74,.88,.55,.9,.46,.62]);
  buildScatter('c-scatter');buildHistogram('c-hist');
  buildGauge('c-gauge',63);buildDonut('c-donut');buildRings('c-rings');buildEq('c-eq');
  buildHeatmap('c-heat');buildBullet('c-bullet');buildNodeGraph('c-node');
  buildRadar('p-radar',[.92,.78,.7,.95,.74,.88]);buildGauge('p-gauge',63);buildLineArea('m-draw');
}

/* ───────────────── TABLE (sortable) ───────────────── */
const slips=[
  {id:'0047',nm:'amber-blitz',st:'live',stake:500,line:210,pl:null},
  {id:'0046',nm:'lilac-meridian',st:'settled',stake:750,line:-110,pl:682},
  {id:'0045',nm:'quiet-audible',st:'void',stake:0,line:0,pl:0},
  {id:'0044',nm:'vesper-arc',st:'lost',stake:400,line:-110,pl:-400},
  {id:'0043',nm:'cobalt-run',st:'settled',stake:300,line:140,pl:418},
];
let sortK='pl',sortT='n',sortDir=-1;
function stPill(s){const m={live:['live','RUNNING','live'],settled:['settled','SETTLED','lilac'],void:['void','VOID','idle'],lost:['lost','LOST','coral'],queued:['queued','QUEUED','idle']}[s];return '<span class="st '+m[0]+'"><span class="dot '+m[2]+'"></span>'+m[1]+'</span>';}
function plCell(p){if(p===null)return '<span class="num" style="color:var(--ink-4)">&mdash; live &mdash;</span>';if(p===0)return '<span class="num">&mdash;</span>';return '<span class="num pl '+(p>0?'up':'dn')+'">'+(p>0?'+':'')+p+'</span>';}
function renderTbl(){
  const rows=[...slips].sort((a,b)=>{let av=a[sortK],bv=b[sortK];if(sortK==='pl'){av=av==null?-1e9:av;bv=bv==null?-1e9:bv;}if(sortT==='s')return String(av).localeCompare(String(bv))*sortDir;return (av-bv)*sortDir;});
  document.querySelector('#tbl1 tbody').innerHTML=rows.map(r=>'<tr><td class="id">'+r.id+'</td><td class="nm">'+r.nm+'</td><td>'+stPill(r.st)+'</td><td class="num">'+(r.stake||'&mdash;')+'</td><td class="num">'+(r.line?(r.line>0?'+':'')+r.line:'&mdash;')+'</td><td>'+plCell(r.pl)+'</td></tr>').join('');
  document.querySelectorAll('#tbl1 th[data-k]').forEach(th=>{th.classList.toggle('sort',th.dataset.k===sortK);let ar=th.querySelector('.ar');if(!ar){ar=document.createElement('span');ar.className='ar';th.appendChild(ar);}ar.textContent=th.dataset.k===sortK?(sortDir<0?' \u25BC':' \u25B2'):'';});
}
function wireTable(){
  document.querySelectorAll('#tbl1 th[data-k]').forEach(th=>{th.onclick=()=>{const k=th.dataset.k;if(k===sortK)sortDir*=-1;else{sortK=k;sortT=th.dataset.t;sortDir=(th.dataset.t==='n')?-1:1;}renderTbl();};});
  renderTbl();
}

/* ───────────────── INTERACTIONS ───────────────── */
function wireInputs(){
  // select
  const sel=document.getElementById('sel1');
  if(sel){sel.querySelector('.sel-btn').onclick=e=>{e.stopPropagation();sel.classList.toggle('open');};
    sel.querySelectorAll('.sel-opt').forEach(o=>o.onclick=()=>{sel.querySelectorAll('.sel-opt').forEach(x=>x.classList.remove('sel-on'));o.classList.add('sel-on');document.getElementById('sel1v').textContent=o.textContent;sel.classList.remove('open');});}
  // steppers
  document.querySelectorAll('.stepper').forEach(b=>b.onclick=()=>{const inp=b.dataset.target?document.getElementById(b.dataset.target):b.closest('.stepper-group').querySelector('.stepin');inp.value=Math.max(0,(+inp.value||0)+(+b.dataset.step));if(inp.id==='dstk')updateDret();});
  // switches
  document.querySelectorAll('[data-switch]').forEach(s=>s.onclick=()=>s.classList.toggle('on'));
  // segmented
  document.querySelectorAll('#seg1 b').forEach(b=>b.onclick=()=>{b.parentNode.querySelectorAll('b').forEach(x=>x.classList.remove('on'));b.classList.add('on');});
  // range
  const rng=document.getElementById('rng');
  if(rng){const upd=()=>{const p=rng.value;document.getElementById('rngv').textContent=p+'%';rng.style.background='linear-gradient(90deg,var(--lilac) '+p+'%,rgba(255,255,255,.08) '+p+'%)';};rng.oninput=upd;upd();}
  // checks + radios + chips
  document.querySelectorAll('[data-check]').forEach(c=>c.onclick=()=>c.classList.toggle('on'));
  document.querySelectorAll('#radios [data-radio]').forEach(r=>r.onclick=()=>{document.querySelectorAll('#radios [data-radio]').forEach(x=>x.classList.remove('on'));r.classList.add('on');});
  document.querySelectorAll('#chips1 .chipx').forEach(c=>c.onclick=()=>c.classList.toggle('on'));
  // tabs + pager
  document.querySelectorAll('#tabs1 .tab').forEach(t=>t.onclick=()=>{document.querySelectorAll('#tabs1 .tab').forEach(x=>x.classList.remove('on'));t.classList.add('on');});
  document.querySelectorAll('#pager1 .page').forEach(p=>p.onclick=()=>{document.querySelectorAll('#pager1 .page').forEach(x=>x.classList.remove('on'));p.classList.add('on');});
  // popover
  const pb=document.getElementById('popBtn');
  if(pb)pb.onclick=e=>{e.stopPropagation();document.getElementById('pop1').classList.toggle('open');};
}
function updateDret(){const stake=+document.getElementById('dstk').value||0;document.getElementById('dret').innerHTML='\u25C8 '+Math.round(stake*7.12).toLocaleString();}

/* outside-click closers */
document.addEventListener('click',e=>{
  const sel=document.getElementById('sel1');if(sel&&sel.classList.contains('open')&&!sel.contains(e.target))sel.classList.remove('open');
  const pop=document.getElementById('pop1');if(pop&&pop.classList.contains('open')&&!pop.contains(e.target)&&e.target.id!=='popBtn')pop.classList.remove('open');
});

/* ───────────────── OVERLAYS ───────────────── */
function toast(msg,cls){cls=cls||'';const t=document.createElement('div');t.className='toast '+cls;
  t.innerHTML='<span class="dot '+(cls==='ok'?'live':cls==='warn'?'amber':cls==='danger'?'coral':'lilac')+'"></span>'+msg;
  document.getElementById('toasts').appendChild(t);
  setTimeout(()=>{t.style.transition='.4s';t.style.opacity='0';t.style.transform='translateY(10px)';setTimeout(()=>t.remove(),400);},2600);}
function openModal(){document.getElementById('modal').classList.add('open');}
function closeModal(){document.getElementById('modal').classList.remove('open');}
function openDrawer(){document.getElementById('drawer').classList.add('open');}
function closeDrawer(){document.getElementById('drawer').classList.remove('open');}

/* ───────────────── COMMAND PALETTE ───────────────── */
const cmds=[
  {i:'\u25A1',l:'Jump to Charts',k:'G C',fn:()=>jump('charts')},
  {i:'\u25A1',l:'Jump to Patterns',k:'G P',fn:()=>jump('patterns')},
  {i:'\u25A1',l:'Jump to Foundations',k:'G F',fn:()=>jump('foundations')},
  {i:'\u25C8',l:'Open parlay drawer',k:'D',fn:openDrawer},
  {i:'\u25C9',l:'Open modal dialog',k:'M',fn:openModal},
  {i:'\u2726',l:'Fire a success toast',k:'T',fn:()=>toast('Hello from the command palette','ok')},
  {i:'\u21BB',l:'Replay all charts',k:'R',fn:()=>renderAllCharts()},
];
let cmFilter='',cmSel=0,cmItems=cmds;
function renderCmds(){
  const list=document.getElementById('cmdlist');cmItems=cmds.filter(c=>c.l.toLowerCase().includes(cmFilter.toLowerCase()));
  if(cmSel>=cmItems.length)cmSel=Math.max(0,cmItems.length-1);
  list.innerHTML=cmItems.map((c,i)=>'<div class="cmditem '+(i===cmSel?'sel':'')+'" data-idx="'+i+'"><span class="ci">'+c.i+'</span><span class="cl">'+c.l+'</span><span class="ck">'+(c.k||'')+'</span></div>').join('')||'<div class="cmditem" style="opacity:.5">No matches</div>';
  list.querySelectorAll('.cmditem[data-idx]').forEach(el=>el.onclick=()=>{cmItems[+el.dataset.idx].fn();closeCmd();});
}
function openCmd(){document.getElementById('cmdk').classList.add('open');const inp=document.getElementById('cmdinput');inp.value='';cmFilter='';cmSel=0;renderCmds();setTimeout(()=>inp.focus(),30);}
function closeCmd(){document.getElementById('cmdk').classList.remove('open');}
function jump(id){closeCmd();const t=document.getElementById(id);if(t)t.scrollIntoView({behavior:'smooth',block:'start'});}

/* ───────────────── RAIL SCROLL-SPY ───────────────── */
function wireRail(){
  const ris=[...document.querySelectorAll('#rail .ri')];
  ris.forEach(ri=>ri.onclick=()=>{const t=document.getElementById(ri.dataset.target);if(t)t.scrollIntoView({behavior:'smooth',block:'start'});});
  const secs=[...document.querySelectorAll('#main .sec')];
  const io=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){ris.forEach(r=>r.classList.toggle('active',r.dataset.target===e.target.id));}});},{root:document.getElementById('main'),rootMargin:'-15% 0px -75% 0px',threshold:0});
  secs.forEach(s=>io.observe(s));
}

/* ───────────────── MOTION DEMOS ───────────────── */
function rollTo(el,target){if(RM){el.textContent=target.toLocaleString();return;}let c=0;const step=target/40;const iv=setInterval(()=>{c+=step;if(c>=target){c=target;clearInterval(iv);}el.textContent=Math.round(c).toLocaleString();},20);}
function playCount(){rollTo(document.getElementById('m-count'),12480);}
function playStage(){
  const s=document.getElementById('m-stage'),bar=document.getElementById('m-stagebar');bar.style.opacity='1';s.style.color='var(--steel)';
  const stages=['Seeding 10,000 states\u2026','Modeling game script\u2026','Applying priors\u2026','Aggregating outcomes\u2026'];let i=0;s.textContent=stages[0];
  const iv=setInterval(()=>{i++;if(i<stages.length){s.textContent=stages[i];}else{clearInterval(iv);s.innerHTML='<span style="color:var(--jade)">\u2713 Complete \u00b7 10,000 runs</span>';setTimeout(()=>{bar.style.opacity='.4';},700);}},RM?60:550);
}
function playDraw(){buildLineArea('m-draw');}

/* ───────────────── CLOCK + BOOT + INIT ───────────────── */
function tickClock(){const d=new Date(),p=n=>String(n).padStart(2,'0');const el=document.getElementById('clock');if(el)el.textContent=p(d.getHours())+':'+p(d.getMinutes())+':'+p(d.getSeconds());}
function skipBoot(){document.getElementById('boot').classList.add('gone');document.getElementById('app').classList.add('live');}
const bootLines=['HASHMARK UI \u00b7 interface system','> loading <b>design tokens</b> ......... <span class="ok">OK</span>','> mounting component registry .... <span class="ok">142 OK</span>','> compiling <b>18 chart generators</b> . <span class="ok">OK</span>','> AUSPEX visual language ready.'];
(function boot(){
  const log=document.getElementById('bootlog');
  if(RM){document.getElementById('boot').classList.add('gone');document.getElementById('app').classList.add('live');return;}
  let i=0;const step=()=>{if(i<bootLines.length){log.innerHTML+=bootLines[i]+'<br>';i++;setTimeout(step,260);}};step();
  setTimeout(()=>{document.getElementById('boot').classList.add('gone');document.getElementById('app').classList.add('live');},2200);
  document.getElementById('boot').onclick=skipBoot;
})();

/* global keys */
addEventListener('keydown',e=>{
  if((e.metaKey||e.ctrlKey)&&e.key.toLowerCase()==='k'){e.preventDefault();document.getElementById('cmdk').classList.contains('open')?closeCmd():openCmd();return;}
  if(e.key==='Escape'){closeCmd();closeModal();closeDrawer();const p=document.getElementById('pop1');if(p)p.classList.remove('open');}
  if(document.getElementById('cmdk').classList.contains('open')){
    if(e.key==='ArrowDown'){e.preventDefault();cmSel=Math.min(cmItems.length-1,cmSel+1);renderCmds();}
    if(e.key==='ArrowUp'){e.preventDefault();cmSel=Math.max(0,cmSel-1);renderCmds();}
    if(e.key==='Enter'){e.preventDefault();if(cmItems[cmSel]){cmItems[cmSel].fn();closeCmd();}}
  }
});

/* motion pause toggle */
(function(){const ps=document.createElement('style');ps.textContent='body.paused *{animation-play-state:paused!important}';document.head.appendChild(ps);
  document.getElementById('motionToggle').onclick=function(){document.body.classList.toggle('paused');this.classList.toggle('on');};})();

document.getElementById('cmdtrigger').onclick=openCmd;
document.getElementById('cmdinput').oninput=e=>{cmFilter=e.target.value;cmSel=0;renderCmds();};
document.getElementById('cmdk').onclick=e=>{if(e.target.id==='cmdk')closeCmd();};
document.getElementById('modal').onclick=e=>{if(e.target.id==='modal')closeModal();};

/* INIT */
renderAllCharts();
wireTable();
wireInputs();
wireRail();
renderCmds();
updateDret();
tickClock();setInterval(tickClock,1000);
</script>
</body>
