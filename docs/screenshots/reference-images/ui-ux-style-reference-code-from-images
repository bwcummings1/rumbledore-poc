    g+='<circle cx="75" cy="75" r="'+r+'" fill="none" stroke="'+s.c+'" stroke-width="15" stroke-dasharray="'+(RM?len:0)+' '+(RM?(Cc-len):Cc)+'" stroke-dashoffset="'+(-(a/100)*Cc).toFixed(1)+'">'+anim('<animate attributeName="stroke-dasharray" from="0 '+Cc.toFixed(1)+'" to="'+len.toFixed(1)+' '+(Cc-len).toFixed(1)+'" dur="0.8s" begin="'+(i*0.12)+'s" fill="freeze"/>')+'</circle>';a+=s.v;});
  g+='</g><text x="75" y="72" text-anchor="middle" font-family="JetBrains Mono" font-size="20" font-weight="500" fill="'+C.lilac+'">42%</text>';
  g+='<text x="75" y="86" text-anchor="middle" font-family="JetBrains Mono" font-size="8" letter-spacing="1.5" fill="'+C.ink3+'">PASS</text></svg>';
