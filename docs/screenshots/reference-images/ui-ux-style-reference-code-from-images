}
/* ───────── donut ───────── */
function buildDonut(id){
  const segs=[{v:42,c:C.lilac},{v:28,c:C.steel},{v:18,c:C.amber},{v:12,c:C.jade}];
  const r=52,Cc=2*Math.PI*r;let a=0;
  let g='<svg viewBox="0 0 150 150" style="width:100%;max-width:158px;height:auto;display:block"><g transform="rotate(-90 75 75)">';
