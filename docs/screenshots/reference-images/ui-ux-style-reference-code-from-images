function rOpen(W,H){return '<svg viewBox="0 0 '+W+' '+H+'" style="width:100%;height:auto;overflow:visible;display:block">';}
function hgrid(W,H,pad,rows){let g='';for(let r=0;r<=rows;r++){const y=pad+r*(H-pad*2)/rows;g+='<line x1="'+pad+'" y1="'+y+'" x2="'+(W-pad)+'" y2="'+y+'" stroke="'+C.hair+'" stroke-width="1"/>';}return g;}
function clipV(cid,W,H){return '<clipPath id="'+cid+'"><rect x="0" y="'+(RM?0:H)+'" width="'+W+'" height="'+(RM?H:0)+'">'+anim('<animate attributeName="y" from="'+H+'" to="0" dur="0.8s" fill="freeze"/><animate attributeName="height" from="0" to="'+H+'" dur="0.8s" fill="freeze"/>')+'</rect></clipPath>';}
function clipH(cid,W,H){return '<clipPath id="'+cid+'"><rect x="0" y="0" width="'+(RM?W:0)+'" height="'+H+'">'+anim('<animate attributeName="width" from="0" to="'+W+'" dur="0.9s" fill="freeze"/>')+'</rect></clipPath>';}
function put(id,svg,post){const el=document.getElementById(id);if(!el)return;el.innerHTML=svg;if(post){RM?post():requestAnimationFrame(post);}}
function drawIn(pid){if(RM)return;const p=document.getElementById(pid);if(!p)return;try{const len=p.getTotalLength();p.style.strokeDasharray=len;p.style.strokeDashoffset=len;p.animate([{strokeDashoffset:len},{strokeDashoffset:0}],{duration:1300,easing:'cubic-bezier(.5,.05,.2,1)',fill:'forwards'});}catch(e){}}

/* ───────── line + area ───────── */
function buildLineArea(id){
  const data=[0.4,0.5,0.45,0.58,0.54,0.64,0.6,0.7,0.66,0.75,0.72,0.83];
  const W=320,H=150,pad=16,X=i=>pad+i/(data.length-1)*(W-pad*2),Y=v=>H-pad-v*(H-pad*2);
  const pts=data.map((v,i)=>[X(i),Y(v)]),pid='ln-'+id;
  let g=rOpen(W,H)+hgrid(W,H,pad,3);
  g+='<defs><linearGradient id="lg-'+id+'" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="'+C.lilac+'" stop-opacity=".3"/><stop offset="1" stop-color="'+C.lilac+'" stop-opacity="0"/></linearGradient></defs>';
  g+='<path d="'+lpath(pts)+' L '+X(data.length-1)+' '+(H-pad)+' L '+pad+' '+(H-pad)+' Z" fill="url(#lg-'+id+')"/>';
  g+='<path id="'+pid+'" d="'+lpath(pts)+'" fill="none" stroke="'+C.lilac+'" stroke-width="2" stroke-linejoin="round"/>';
  g+='<circle cx="'+X(data.length-1)+'" cy="'+Y(data[data.length-1]).toFixed(1)+'" r="3.2" fill="'+C.lilacHi+'">'+anim('<animate attributeName="r" values="3.2;5;3.2" dur="2s" repeatCount="indefinite"/>')+'</circle>';
  g+='</svg>';put(id,g,()=>drawIn(pid));
}
/* ───────── multi-series ───────── */
function buildMultiLine(id){
  const A=[0.5,0.45,0.55,0.5,0.6,0.58,0.66,0.62,0.7,0.74],B=[0.5,0.52,0.54,0.57,0.6,0.63,0.66,0.69,0.71,0.73];
  const W=320,H=150,pad=16,X=i=>pad+i/(A.length-1)*(W-pad*2),Y=v=>H-pad-v*(H-pad*2);
  const pa=A.map((v,i)=>[X(i),Y(v)]),pb=B.map((v,i)=>[X(i),Y(v)]);
  let g=rOpen(W,H)+hgrid(W,H,pad,3);
  g+='<path d="'+lpath(pb)+'" fill="none" stroke="'+C.ink3+'" stroke-width="1.4" stroke-dasharray="3 4"/>';
  g+='<path id="ml-'+id+'" d="'+lpath(pa)+'" fill="none" stroke="'+C.lilac+'" stroke-width="2" stroke-linejoin="round"/>';
  g+='<circle cx="'+X(A.length-1)+'" cy="'+Y(A[A.length-1]).toFixed(1)+'" r="3" fill="'+C.lilacHi+'"/></svg>';
  put(id,g,()=>drawIn('ml-'+id));
}
/* ───────── sparklines (HTML) ───────── */
function buildSpark(id){
  const sets=[['Targets',[4,6,5,8,7,9,11],C.lilac],['Snaps',[55,58,52,60,57,64,71],C.steel],['Edge %',[2.1,1.8,3,2.6,4.1,3.4,4.4],C.amber]];
  const rows=sets.map(s=>{const d=s[1],W=120,H=26,pad=3,mx=Math.max(...d),mn=Math.min(...d);
    const X=i=>pad+i/(d.length-1)*(W-pad*2),Y=v=>H-pad-((v-mn)/((mx-mn)||1))*(H-pad*2);
    const pts=d.map((v,i)=>[X(i),Y(v)]);
    return '<div class="row between" style="gap:10px"><span class="mlab" style="width:52px;font-size:9px">'+s[0]+'</span><svg viewBox="0 0 '+W+' '+H+'" preserveAspectRatio="none" style="flex:1;height:22px"><polyline points="'+pts.map(p=>p.join(',')).join(' ')+'" fill="none" stroke="'+s[2]+'" stroke-width="1.6" stroke-linejoin="round"/><circle cx="'+X(d.length-1)+'" cy="'+Y(d[d.length-1]).toFixed(1)+'" r="2" fill="'+s[2]+'"/></svg><span class="num" style="width:32px;text-align:right;font-size:10px">'+d[d.length-1]+'</span></div>';
  }).join('');
  const el=document.getElementById(id);if(el)el.innerHTML='<div class="col" style="gap:13px">'+rows+'</div>';
}
/* ───────── vertical bars ───────── */
function buildBars(id){
  const data=[12,19,9,24,16,21,14,27],W=300,H=150,pad=16,n=data.length,bw=(W-pad*2)/n,mx=Math.max(...data),max=mx*1.1;
  let g=rOpen(W,H)+hgrid(W,H,pad,3)+'<defs>'+clipV('cb-'+id,W,H)+'</defs><g clip-path="url(#cb-'+id+')">';
  data.forEach((v,i)=>{const bh=(v/max)*(H-pad*2),x=pad+i*bw+bw*0.2,y=H-pad-bh,w=bw*0.6;
    g+='<rect x="'+x+'" y="'+y+'" width="'+w+'" height="'+bh+'" rx="2.5" fill="'+(v===mx?C.amber:C.lilac)+'" opacity="'+(v===mx?1:.85)+'"/>';});
  g+='</g></svg>';put(id,g);
}
/* ───────── grouped bars ───────── */
function buildGrouped(id){
  const groups=[[18,14],[22,19],[12,16],[25,20],[16,13]],W=300,H=150,pad=16,n=groups.length,gw=(W-pad*2)/n,max=27;
  let g=rOpen(W,H)+hgrid(W,H,pad,3)+'<defs>'+clipV('cg-'+id,W,H)+'</defs><g clip-path="url(#cg-'+id+')">';
  groups.forEach((pair,i)=>{const x0=pad+i*gw;pair.forEach((v,j)=>{const bh=(v/max)*(H-pad*2),bw=gw*0.28,x=x0+gw*0.16+j*(bw+3),y=H-pad-bh;
    g+='<rect x="'+x+'" y="'+y+'" width="'+bw+'" height="'+bh+'" rx="2" fill="'+(j?C.steel:C.lilac)+'"/>';});});
  g+='</g></svg>';put(id,g);
}
/* ───────── stacked bars ───────── */
function buildStacked(id){
  const cols=[[10,8,6],[12,7,9],[9,11,5],[14,6,8],[11,9,7],[13,8,10]],W=300,H=150,pad=16,n=cols.length,bw=(W-pad*2)/n,cl=[C.lilac,C.steel,C.amber];
  const max=Math.max(...cols.map(c=>c.reduce((a,b)=>a+b,0)))*1.12;
  let g=rOpen(W,H)+hgrid(W,H,pad,3)+'<defs>'+clipV('cs-'+id,W,H)+'</defs><g clip-path="url(#cs-'+id+')">';
  cols.forEach((c,i)=>{let ya=H-pad;const x=pad+i*bw+bw*0.22,w=bw*0.56;c.forEach((v,j)=>{const bh=(v/max)*(H-pad*2);ya-=bh;g+='<rect x="'+x+'" y="'+ya+'" width="'+w+'" height="'+bh+'" fill="'+cl[j]+'" opacity="'+(0.72+j*0.12)+'"/>';});});
  g+='</g></svg>';put(id,g);
}
/* ───────── horizontal ranking ───────── */
function buildHBars(id){
  const rows=[['Bell',96],['Mercer',88],['Frost',78],['Brooks',71],['Reynolds',54]];
  const W=300,H=150,padX=8,padY=10,n=rows.length,rh=(H-padY*2)/n,max=100,lblW=58,trackX=lblW+6,trackW=W-trackX-30;
  let g=rOpen(W,H)+'<defs>'+clipH('ch-'+id,W,H)+'</defs>';
  rows.forEach((r,i)=>{const y=padY+i*rh+rh/2;g+='<text x="'+padX+'" y="'+(y+3)+'" font-family="JetBrains Mono" font-size="9" fill="'+C.ink+'">'+r[0]+'</text>';g+='<rect x="'+trackX+'" y="'+(y-5)+'" width="'+trackW+'" height="10" rx="5" fill="rgba(255,255,255,.05)"/>';});
  g+='<g clip-path="url(#ch-'+id+')">';
  rows.forEach((r,i)=>{const y=padY+i*rh+rh/2,w=r[1]/max*trackW;g+='<rect x="'+trackX+'" y="'+(y-5)+'" width="'+w+'" height="10" rx="5" fill="'+(i===0?C.amber:C.lilac)+'"/>';});
  g+='</g>';
  rows.forEach((r,i)=>{const y=padY+i*rh+rh/2;g+='<text x="'+(W-padX)+'" y="'+(y+3)+'" text-anchor="end" font-family="JetBrains Mono" font-size="9" fill="'+C.ink2+'">'+r[1]+'</text>';});
  g+='</svg>';put(id,g);
}
/* ───────── range (floor/median/ceiling) ───────── */
function buildRange(id){
  const rows=[['Bell',12,22.6,31],['Brooks',9,16.9,24],['Frost',5,15.2,27],['Mercer',19,24,31]];
  const W=300,H=150,padX=8,padY=14,n=rows.length,rh=(H-padY*2)/n,smax=34,lblW=54,trackX=lblW+4,trackW=W-trackX-10;
  const xv=v=>trackX+v/smax*trackW;let g=rOpen(W,H);
  rows.forEach((r,i)=>{const y=padY+i*rh+rh/2;
    g+='<text x="'+padX+'" y="'+(y+3)+'" font-family="JetBrains Mono" font-size="9" fill="'+C.ink2+'">'+r[0]+'</text>';
    g+='<line x1="'+trackX+'" y1="'+y+'" x2="'+(trackX+trackW)+'" y2="'+y+'" stroke="rgba(255,255,255,.05)" stroke-width="6" stroke-linecap="round"/>';
    g+='<line x1="'+xv(r[1])+'" y1="'+y+'" x2="'+xv(r[3])+'" y2="'+y+'" stroke="'+C.lilac+'" stroke-width="6" stroke-linecap="round" opacity=".85">'+anim('<animate attributeName="x2" from="'+xv(r[1])+'" to="'+xv(r[3])+'" dur="0.8s" fill="freeze"/>')+'</line>';
    g+='<circle cx="'+xv(r[2])+'" cy="'+y+'" r="4" fill="'+C.amber+'" stroke="#0b0c14" stroke-width="1.5"/>';});
  g+='</svg>';put(id,g);
}
/* ───────── radar / spider ───────── */
function buildRadar(id,A,B){
  const AX=['VOLUME','EFFICIENCY','MATCHUP','CEILING','FLOOR','FORM'],S=200,c=S/2,R=64,rings=4;
  const ang=i=>(-90+i*60)*Math.PI/180,pt=(i,r)=>[c+Math.cos(ang(i))*r,c+Math.sin(ang(i))*r];
  let g='<svg viewBox="0 0 '+S+' '+S+'" style="width:100%;max-width:200px;height:auto;display:block">';
  for(let k=1;k<=rings;k++){const r=R*k/rings;g+='<polygon points="'+AX.map((_,i)=>pt(i,r).join(',')).join(' ')+'" fill="none" stroke="'+C.hair+'" stroke-width="1"/>';}
  AX.forEach((ax,i)=>{const p=pt(i,R);g+='<line x1="'+c+'" y1="'+c+'" x2="'+p[0]+'" y2="'+p[1]+'" stroke="'+C.hair+'" stroke-width="1"/>';
    const l=pt(i,R+15),an=Math.abs(l[0]-c)<6?'middle':(l[0]>c?'start':'end');
    g+='<text x="'+l[0]+'" y="'+(l[1]+3)+'" text-anchor="'+an+'" font-family="Saira" font-size="8" letter-spacing="1" fill="'+C.ink3+'">'+ax+'</text>';});
  if(B){g+='<polygon points="'+B.map((v,i)=>pt(i,R*v).join(',')).join(' ')+'" fill="rgba(130,178,208,.16)" stroke="'+C.steel+'" stroke-width="1.6"/>';
    B.forEach((v,i)=>{const p=pt(i,R*v);g+='<circle cx="'+p[0]+'" cy="'+p[1]+'" r="2.2" fill="'+C.steelSoft+'"/>';});}
  g+='<polygon class="rdr-'+id+'" points="'+A.map((v,i)=>pt(i,R*v).join(',')).join(' ')+'" fill="rgba(167,169,236,.18)" stroke="'+C.lilac+'" stroke-width="2" style="filter:drop-shadow(0 0 5px rgba(167,169,236,.5));transform-origin:center"/>';
  A.forEach((v,i)=>{const p=pt(i,R*v);g+='<circle cx="'+p[0]+'" cy="'+p[1]+'" r="2.6" fill="'+C.lilacHi+'"/>';});
  g+='</svg>';
  put(id,g,()=>{const poly=document.querySelector('.rdr-'+id);if(poly)poly.animate([{transform:'scale(.85)',opacity:.3},{transform:'scale(1)',opacity:1}],{duration:500,easing:'cubic-bezier(.2,.8,.2,1)'});});
}
