/* ───────── heatmap ───────── */
function buildHeatmap(id){
  const cols=8,rowsN=5,W=260,H=150,pad=10,gap=3,cw=(W-pad*2)/cols,chh=(H-pad*2)/rowsN;let g=rOpen(W,H);
  for(let r=0;r<rowsN;r++)for(let c=0;c<cols;c++){const v=Math.pow(Math.random(),1.3),x=pad+c*cw,y=pad+r*chh,hot=v>.78;
    const fill=hot?'rgba(226,178,102,'+(0.5+v*0.4).toFixed(2)+')':'rgba(167,169,236,'+(0.10+v*0.72).toFixed(2)+')';
    g+='<rect x="'+(x+gap/2)+'" y="'+(y+gap/2)+'" width="'+(cw-gap)+'" height="'+(chh-gap)+'" rx="2.5" fill="'+fill+'" opacity="'+(RM?1:0)+'">'+anim('<animate attributeName="opacity" from="0" to="1" dur="0.4s" begin="'+((r*cols+c)*0.014).toFixed(2)+'s" fill="freeze"/>')+'</rect>';}
  g+='</svg>';put(id,g);
}
/* ───────── bullet ───────── */
function buildBullet(id){
  const rows=[['Proj',22.6,20],['Floor',16.1,18],['Ceiling',28.3,26]];
  const W=300,H=120,padX=8,padY=14,n=rows.length,rh=(H-padY*2)/n,lblW=54,trackX=lblW+4,trackW=W-trackX-30,max=32,xv=v=>trackX+v/max*trackW;
